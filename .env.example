# Copy this file to `.env` (same directory) and fill in real values.
# `.env` is gitignored. `.env.example` is committed as a template.

# NewsAPI.org free tier — https://newsapi.org/register
# Required for data_news.newsapi_fetcher; if unset the fetcher returns [] silently.
NEWSAPI_KEY=

# Anthropic Console — https://console.anthropic.com
# Required for Plan 2 (LangGraph agents via langchain-anthropic).
ANTHROPIC_API_KEY=
